def bubble_sort(arr):
    n = len(arr)
    
    for i in range(n):
        # Last i elements are already sorted
        for j in range(0, n - i - 1):
            if arr[j] > arr[j + 1]:
                # Swap
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
    
    return arr


# Example usage
data = [64, 34, 25, 12, 22, 11, 90]
print("Sorted array (Bubble Sort):", bubble_sort(data))
